{
  "rpc": {
    "url": "http://localhost:1818",
    "ws_url": "ws://localhost:1819/stratum",
    "timeout_seconds": 30,
    "max_retries": 5,
    "retry_delay_seconds": 2
  },
  "pools": [
    {
      "name": "NogoPool",
      "url": "http://localhost:1818",
      "ws_url": "ws://localhost:1819/stratum",
      "address": "NOGO<your_address_here>",
      "priority": 1,
      "enabled": true
    }
  ],
  "miner": {
    "threads": 0,
    "batch_size": 1000,
    "share_difficulty": 0
  },
  "logging": {
    "level": "info",
    "file": "nogominer.log",
    "max_size_mb": 10,
    "max_backups": 3,
    "max_age_days": 30,
    "compress": true,
    "json_format": false
  },
  "monitor": {
    "enabled": true,
    "update_interval_seconds": 10,
    "prometheus_enabled": false,
    "prometheus_port": 9090
  }
}
